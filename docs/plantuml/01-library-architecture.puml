@startuml
skinparam backgroundColor white
skinparam componentStyle rectangle
skinparam shadowing false
skinparam defaultTextAlignment center
skinparam ArrowColor #4b5563
skinparam ComponentBorderColor #1f2937
skinparam ComponentBackgroundColor #f8fafc
skinparam DatabaseBorderColor #1f2937
skinparam DatabaseBackgroundColor #eef2ff

title Архитектура библиотеки DeviceTypesImportExport

package "Приложение-интегратор" {
  [DeviceTemplateLibraryFacade\nкак Facade] as Facade
}

package "device-template-library" {
  [DttArchiveReader/Writer\nZIP + YAML + Groovy] as Archive
  [TemplateValidationService\nвалидация шаблона] as Validation
  [TemplateAssemblyService\nсборка profile/branch] as Assembly
  [Profile/Branch JSON Parsers\nparse/generate JSON] as Parsers
  [Canonical mappers\narchive <-> canonical <-> projection] as Canonical
}

database "DTT archive" as DTT
collections "EquipmentProfile / BranchEquipment" as MODELS
collections "profile JSON / branch JSON" as JSON

Facade --> Archive : read/write DTT
Facade --> Validation : validate
Facade --> Assembly : assemble/import/preview
Facade --> Parsers : parse/toJson/exportFromJson
Archive --> DTT
Assembly --> MODELS
Parsers --> JSON
Canonical ..> Archive
Canonical ..> Assembly
@enduml
